{
  "type": "object",
  "required": [
    "card_name",
    "service_context",
    "review_owner",
    "last_reviewed",
    "ai_role",
    "not_ai_decisions",
    "human_review_triggers",
    "recourse_path",
    "evidence_to_include",
    "repair_commitments",
    "response_time_expectation",
    "boundary_notes"
  ],
  "properties": {
    "card_name": {
      "type": "string"
    },
    "service_context": {
      "type": "string"
    },
    "review_owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    },
    "ai_role": {
      "type": "string"
    },
    "not_ai_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "human_review_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "trigger",
          "human_owner",
          "why"
        ],
        "properties": {
          "trigger": {
            "type": "string"
          },
          "human_owner": {
            "type": "string"
          },
          "why": {
            "type": "string"
          }
        }
      }
    },
    "recourse_path": {
      "type": "object",
      "required": [
        "visible_label",
        "contact_route",
        "appeal_or_review_step",
        "fallback_if_no_response"
      ],
      "properties": {
        "visible_label": {
          "type": "string"
        },
        "contact_route": {
          "type": "string"
        },
        "appeal_or_review_step": {
          "type": "string"
        },
        "fallback_if_no_response": {
          "type": "string"
        }
      }
    },
    "evidence_to_include": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "verification_context": {
      "type": "object",
      "properties": {
        "claimed_authority": {"type": "string"},
        "source_of_truth": {"type": "string"},
        "evidence_to_preserve_before_action": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "repair_commitments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "response_time_expectation": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "needs_owner_review",
        "ready_for_pilot",
        "do_not_use_until_reviewed"
      ]
    },
    "boundary_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
