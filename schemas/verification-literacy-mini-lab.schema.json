{
  "type": "object",
  "required": ["lab_name", "scenario", "audience", "facilitator", "last_reviewed", "learning_goal", "claims_or_messages", "verification_steps", "reflection_prompts", "safe_use_boundary"],
  "properties": {
    "lab_name": {"type": "string"},
    "scenario": {"type": "string"},
    "audience": {"type": "string"},
    "facilitator": {"type": "string"},
    "last_reviewed": {"type": "string"},
    "learning_goal": {"type": "string"},
    "duration_minutes": {"type": "string"},
    "claims_or_messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["message", "surface_cues", "possible_source_of_truth", "safe_action", "confidence_before", "confidence_after"],
        "properties": {
          "message": {"type": "string"},
          "surface_cues": {"type": "array", "items": {"type": "string"}},
          "possible_source_of_truth": {"type": "string"},
          "safe_action": {"type": "string"},
          "confidence_before": {"type": "string"},
          "confidence_after": {"type": "string"}
        }
      }
    },
    "verification_steps": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "reflection_prompts": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "status": {"enum": ["draft", "ready_for_classroom_or_workshop_review", "needs_facilitator_review", "do_not_use_until_reviewed"]},
    "safe_use_boundary": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
