{
  "type": "object",
  "required": ["receipt_name", "scenario", "review_owner", "last_reviewed", "contact_events", "verification_route", "do_not_do", "safe_next_step", "boundary_notes"],
  "properties": {
    "receipt_name": {"type": "string"},
    "scenario": {"type": "string"},
    "review_owner": {"type": "string"},
    "last_reviewed": {"type": "string"},
    "contact_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["channel", "claimed_sender", "requested_action", "pressure_tactic", "risk_if_true", "risk_if_fake", "source_of_truth"],
        "properties": {
          "channel": {"type": "string"},
          "claimed_sender": {"type": "string"},
          "requested_action": {"type": "string"},
          "pressure_tactic": {"type": "string"},
          "risk_if_true": {"type": "string"},
          "risk_if_fake": {"type": "string"},
          "source_of_truth": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "verification_route": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "do_not_do": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "safe_next_step": {"type": "string"},
    "status": {"enum": ["draft", "ready_for_personal_use", "needs_owner_review", "do_not_use_until_reviewed"]},
    "boundary_notes": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
