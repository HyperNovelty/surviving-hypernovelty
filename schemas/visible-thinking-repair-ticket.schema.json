{
  "type": "object",
  "required": [
    "title",
    "owner",
    "purpose",
    "review_cadence",
    "status",
    "missing_evidence",
    "repair_requests",
    "acceptable_repair_outcomes",
    "boundary_note"
  ],
  "properties": {
    "title": { "type": "string" },
    "owner": { "type": "string" },
    "purpose": { "type": "string" },
    "review_cadence": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["REPAIR NEEDED", "REPAIR IN PROGRESS", "RESOLVED BY LOCAL REVIEW", "REVIEW AID ONLY"]
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap", "severity"],
        "properties": {
          "gap": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      },
      "minItems": 1
    },
    "repair_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["request", "evidence_type"],
        "properties": {
          "request": { "type": "string" },
          "evidence_type": {
            "type": "string",
            "enum": ["oral_explanation", "source_mapping", "revision_note", "teacher_conference"]
          }
        }
      },
      "minItems": 1
    },
    "acceptable_repair_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["outcome", "disposition"],
        "properties": {
          "outcome": { "type": "string" },
          "disposition": {
            "type": "string",
            "enum": ["accept", "revise", "conference"]
          }
        }
      },
      "minItems": 1
    },
    "sections": {
      "type": "array",
      "items": { "type": "object" }
    },
    "review_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "boundary_note": { "type": "string" },
    "notes": { "type": "string" }
  }
}
