{
  "type": "object",
  "required": [
    "check_name",
    "review_owner",
    "review_date",
    "agent_identity",
    "roster_link",
    "connected_systems",
    "permissions_to_revoke",
    "pause_owner",
    "pause_trigger",
    "revocation_steps",
    "dependent_workflows",
    "evidence_to_preserve",
    "restart_criteria",
    "decision",
    "boundary_note"
  ],
  "properties": {
    "check_name": {"type": "string"},
    "review_owner": {"type": "string"},
    "review_date": {"type": "string"},
    "agent_identity": {"type": "string"},
    "roster_link": {"type": "string"},
    "scenario": {"type": "string"},
    "connected_systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_name", "access_type", "revocation_method", "revocation_owner", "verified_status"],
        "properties": {
          "system_name": {"type": "string"},
          "access_type": {"type": "string"},
          "revocation_method": {"type": "string"},
          "revocation_owner": {"type": "string"},
          "verified_status": {"enum": ["verified", "partly_verified", "not_verified", "unknown"]},
          "notes": {"type": "string"}
        }
      }
    },
    "permissions_to_revoke": {"type": "array", "items": {"type": "string"}},
    "pause_owner": {"type": "string"},
    "pause_trigger": {"type": "string"},
    "revocation_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "owner", "evidence", "status"],
        "properties": {
          "step": {"type": "string"},
          "owner": {"type": "string"},
          "evidence": {"type": "string"},
          "status": {"enum": ["ready", "needs_work", "blocked", "unknown"]}
        }
      }
    },
    "dependent_workflows": {"type": "array", "items": {"type": "string"}},
    "evidence_to_preserve": {"type": "array", "items": {"type": "string"}},
    "restart_criteria": {"type": "array", "items": {"type": "string"}},
    "open_gaps": {"type": "array", "items": {"type": "string"}},
    "decision": {"enum": ["ready_to_test", "test_before_deploy", "pause_until_fixed", "escalate_to_security_owner"]},
    "required_next_action": {"type": "string"},
    "boundary_note": {"type": "string"},
    "notes": {"type": "string"}
  }
}
